# NAI Agent 环境变量示例
# 复制本文件为 .env，填入真实值后启动应用

# ─────────────────────────────────────────
# DeepSeek（事实抽取、JSON 结构化输出）
# ─────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─────────────────────────────────────────
# 火山方舟 / 豆包（主要 LLM + 可见性检测）
# ─────────────────────────────────────────
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 豆包模型 ID（用于 chat、文章生成、反思验证等所有 doubao 路由）
# 默认值：doubao-seed-2-0-lite-260428
DOUBAO_MODEL=

# ─────────────────────────────────────────
# 豆包 Embedding
# ─────────────────────────────────────────
# 如果 embedding 使用独立的 API Key，在此填写；否则留空，回退使用 ARK_API_KEY
ARK_EMBEDDING_API_KEY=

# embedding 模型 ID，默认值：doubao-embedding
ARK_EMBEDDING_MODEL=

# embedding API 端点路径，默认值：/embeddings
ARK_EMBEDDING_ENDPOINT=

# embedding 向量维度（整数），需与模型实际输出一致，变更后需重新索引知识库
ARK_EMBEDDING_DIMENSIONS=

# 向量检索时在 query 前拼接的 instruction（可选）
ARK_EMBEDDING_QUERY_INSTRUCTIONS=

# 向量入库时在 chunk 前拼接的 instruction（可选）
ARK_EMBEDDING_CORPUS_INSTRUCTIONS=

# ─────────────────────────────────────────
# 豆包助手可见性检测
# ─────────────────────────────────────────
# 检测模式：ai_search（默认） | reasoning_search（深度，较慢）
DOUBAO_VISIBILITY_MODE=ai_search

# 设为 true 时强制使用 reasoning_search 深度检测
DOUBAO_VISIBILITY_DEEP_MODE=false

# ─────────────────────────────────────────
# 豆包助手 doubao_app 配置（可见性检测地理上下文）
# ─────────────────────────────────────────
DOUBAO_ASSISTANT_LOCATION_COUNTRY=中国
DOUBAO_ASSISTANT_LOCATION_REGION=
DOUBAO_ASSISTANT_LOCATION_CITY=

# 设为 true 时在请求头中开启 Beta 功能
DOUBAO_ASSISTANT_BETA_HEADER=false

# 豆包助手角色描述（可选，用于 role_description 字段）
DOUBAO_ASSISTANT_ROLE_DESCRIPTION=

# ─────────────────────────────────────────
# 小鲸 soul.md 联系方式覆盖
# ─────────────────────────────────────────
# 覆盖 prompts/soul.md 中「## 联系方式」段的占位内容（[待填写：邮箱/电话/官网]）。
# 留空则使用 soul.md 原文。多行可用 \n 转义。
CONTACT_INFO=
